<div class="body" data-controller="weight-chart" data-workout-ids="<%= @workout_ids.to_json %>">
  <div class="h1">WEIGHT STATISTIC</div>
  <%= line_chart @weight_data,
    id: "weight-chart",
    min: 80,
    max: 90,
    curve: false,
    colors: ["#00b894"],
    label: "Вес (кг)",
    title: "Динамика веса",
    xtitle: "Дата",
    ytitle: "Вес (кг)",
    library: { scales: { y: { min: 80, max: 90} } }
  %>

  <%= javascript_include_tag "weight_chart", defer: true %>
</div>