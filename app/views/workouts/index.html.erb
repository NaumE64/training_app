<div class="container mt-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>📊 История тренировок</h1>
    <%= link_to "➕ Новая тренировка", new_workout_path, class: "btn btn-primary" %>
  </div>

  <% if @workouts.any? %>
    <div class="row">
      <% @workouts.each do |workout| %>
        <div class="col-md-6 col-lg-4 mb-4">
          <div class="card h-100">
            <div class="card-header">
              <div class="d-flex justify-content-between">
                <strong><%= workout.date.strftime("%d.%m.%Y") %></strong>
                <span class="badge bg-secondary"><%= workout.workout_type.name %></span>
              </div>
            </div>
            
            <div class="card-body">
              <!-- Вес -->
              <% if workout.weight_before || workout.weight_after %>
                <div class="mb-2">
                  <small class="text-muted">Вес:</small>
                  <% if workout.weight_before && workout.weight_after %>
                    <span><%= workout.weight_before %> → <%= workout.weight_after %> кг</span>
                    <% diff = workout.weight_after - workout.weight_before %>
                    <span class="<%= diff > 0 ? 'text-danger' : 'text-success' %>">
                      (<%= diff > 0 ? "+" : "" %><%= diff %> кг)
                    </span>
                  <% elsif workout.weight_before %>
                    <span>До: <%= workout.weight_before %> кг</span>
                  <% elsif workout.weight_after %>
                    <span>После: <%= workout.weight_after %> кг</span>
                  <% end %>
                </div>
              <% end %>

              <!-- Упражнения -->
              <div class="mb-3">
                <small class="text-muted">Упражнения:</small>
                <ul class="list-unstyled mb-0">
                  <% workout.workout_exercises.limit(3).each do |we| %>
                    <li class="small">
                      <%= we.exercise.name %> 
                      <% if we.exercise_sets.any? %>
                        <% best_set = we.exercise_sets.max_by(&:weight) %>
                        - <%= best_set.weight %> кг × <%= best_set.reps %>
                      <% end %>
                    </li>
                  <% end %>
                  <% if workout.workout_exercises.size > 3 %>
                    <li class="small text-muted">+ еще <%= workout.workout_exercises.size - 3 %></li>
                  <% end %>
                </ul>
              </div>

              <!-- Статистика -->
              <% exercise_sets_count = workout.workout_exercises.sum { |we| we.exercise_sets.size } %>
              <% total_volume = workout.workout_exercises.sum { |we| we.exercise_sets.sum { |s| s.weight * s.reps } } %>

            <% if exercise_sets_count > 0 %>
              <div class="small text-muted">
                <%= exercise_sets_count %> подходов
                <% if total_volume > 0 %>
                  • Объем: <%= total_volume.round %> кг
                <% end %>
              </div>
            <% end %>
            </div>
            
            <div class="card-footer bg-transparent">
              <%= link_to "Посмотреть", workout_path(workout), class: "btn btn-sm btn-outline-primary" %>
              <%# Позже добавишь workout_path(workout) %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-5">
      <h3 class="text-muted">😴 Тренировок еще нет</h3>
      <p class="text-muted">Создай свою первую тренировку!</p>
      <%= link_to "Создать первую тренировку", new_workout_path, class: "btn btn-primary btn-lg" %>
    </div>
  <% end %>
</div>